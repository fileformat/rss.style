{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "astro",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "types": [
      "@cloudflare/workers-types"
    ]
  },
  "include": [
    ".astro/types.d.ts",
    "src",
    "astro.config.mjs"
  ],
  "exclude": [
    "functions",
    "docs",
    "tmp",
    "dist",
    "_site",
    "node_modules"
  ]
}